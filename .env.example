# ─── Backend API ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_TIMEOUT=30000

# ─── Google Services ──────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_PLATFORM_KEY=
GEMINI_API_KEY=

# ─── Feature Flags (set to "true" to enable real API calls per feature) ───────
# Leave all as "false" (or unset) to keep using mock data during development.
NEXT_PUBLIC_FF_REAL_AUTH=false
NEXT_PUBLIC_FF_REAL_SCHOOLS=false
NEXT_PUBLIC_FF_REAL_BRANCHES=false
NEXT_PUBLIC_FF_REAL_ANALYTICS=false
NEXT_PUBLIC_FF_REAL_BILLING=false
NEXT_PUBLIC_FF_REAL_SETTINGS=false
NEXT_PUBLIC_FF_REAL_ONBOARDING=false
